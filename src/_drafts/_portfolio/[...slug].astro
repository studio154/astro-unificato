---
import GalleryLayout from "@/layouts/GalleryMasonryLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const portfolio = await getCollection("portfolio");
  return portfolio.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;
const portfolioCollection = await getCollection("portfolio");
const entry = portfolioCollection.find((e) => e.slug === slug);

if (!entry) throw new Error(`Portfolio con slug "${slug}" non trovato`);

const { Content } = await entry.render();
---

<GalleryLayout frontmatter={entry.data}>
  <Content />
</GalleryLayout>