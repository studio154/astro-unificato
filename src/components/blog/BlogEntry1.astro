---
const { post } = Astro.props;
const title = post.data.title;
const description = post.data.description;
const url = `/${post.slug}/`;

import Text from "@/components/fundations/elements/Text.astro";
---

<article class="relative flex flex-col group h-full">
  <a href={url} class="absolute inset-0 z-30" aria-label={`Leggi: ${title}`}></a>
  
  <div class="overflow-hidden rounded-lg aspect-[16/9] relative bg-slate-900 backdrop-sepia">
    
    <img
      src="/src/images/blog/8.jpeg" 
      alt=""
      class="absolute inset-0 object-cover w-full h-full opacity-50 grayscale transition duration-700 group-hover:scale-110 group-hover:opacity-30"
    />

    <div class="absolute inset-0 bg-black/40"></div>
    
    <div class="absolute inset-0 flex items-center justify-center p-6 text-center z-10">
       <span 
         class="text-white text-4xl md:text-4xl font-serif  font-[200] tracking-wide leading-tight "
         style="font-family: 'Newsreader', serif;"
       >
         {title}
       </span>
    </div>
  </div>

  <div class="pt-4 mt-4 border-t border-base-200 flex flex-col flex-grow relative z-0">
    <Text 
      tag="h3" 
      variant="textSM" 
      class="font-medium text-base-900 line-clamp-1"
    >
      {title}
    </Text>
    <Text 
      tag="p" 
      variant="textSM" 
      class="text-base-500 mt-1 line-clamp-2 text-m"
    >
      {description}
    </Text>
  </div>
</article>