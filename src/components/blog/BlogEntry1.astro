---
// Assets
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Content
const { title, description, url, image } = {
  url: "/blog/posts/" + Astro.props.post.slug,
  title: Astro.props.post.data.title,
  description: Astro.props.post.data.description,
  image: Astro.props.post.data.image?.url || null,
};
---

<article class="relative flex flex-col group">
  
    <a href={url} title={`Read more: ${title}`} aria-label={`Read blog post: ${title}`} class="absolute inset-0 z-10"></a>
  {image ? (
  <div class="overflow-hidden rounded-lg bg-base-100 aspect-[16/9]">
    <img
      src={image}
      alt={title}
      class="object-cover object-center w-full h-full transition duration-500 group-hover:scale-105"
    />
  </div>
) : (
  <div class="w-full aspect-[3/2] bg-base-100 rounded-lg"></div>
)}
  <div class="pt-4 mt-4 border-t border-base-200">
    <Text tag="h3" variant="textSM" class="font-medium text-base-900"
      >{title}</Text
    >
    <Text tag="p" variant="textSM" class="text-base-500 mt-2"
      >{description}</Text
    >
  </div>
</article>