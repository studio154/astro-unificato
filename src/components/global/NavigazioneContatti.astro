---
// Assets

// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Button from "@/components/fundations/elements/Button.astro";
import NavMenu from '@/components/global/NavigazioneHamburgerStandard.astro';
const currentPath = Astro.url.pathname; // prende la path corrente
---

  <Wrapper variant="standard" >
    
       

      <NavMenu currentPath={currentPath} />
      
    
    <Text
        tag="h1"
        variant="textLG"
        class="font-serif uppercase lg:order-none text-base-900 text-center "
      ><a class="hover:text-base-900 text-gallery-5" href="/">Elio Leonardo Carchidi - Fotografo di Ritratto</a><br>
    </Text>

    <div
      class="items-start pt-2 pb-2 lg:pb-6 text-center uppercase grid grid-cols-1 
      gap-4 lg:gap-6 lg:gap-y-6 mb-4 max-w-2xl m-auto "
    >
     
      <Text
        tag="h1"
        variant="textLG"
        class="order-last font-serif uppercase lg:order-none col-span-full lg:col-span-1: text-base-900"
      >
      Ogni grande progetto nasce da una conversazione. Scrivimi qui: sarà un piacere risponderti personalmente e pianificare insieme il tuo ritratto su misura.


      </Text>
      
      
    </div>
  </Wrapper>
</header>
    
</div>
