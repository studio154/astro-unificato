---
---

<section class="py-12 px-4 md:py-16">
  <div class="max-w-xl mx-auto bg-white rounded-lg shadow-md p-6 md:p-8">

    <form
      action="https://submit-form.com/ZSgDwLQLv"
      method="POST"
      class="space-y-4 md:space-y-5"
    >

      <h2 class="text-xl md:text-2xl font-semibold text-gray-900 mb-8 text-center">
        Scrivimi per il tuo ritratto su misura
      </h2>

      <!-- Honeypot anti-spam -->
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
      <input type="text" name="_honeypot" class="hidden" tabindex="-1" autocomplete="off" />

      <!-- Redirect -->
      <input type="hidden" name="_redirect" value="https://www.eliocarchidi.com/grazie/" />

      <!-- Reply-to -->
      <input type="hidden" name="_replyto" id="replyto-field" />

      <!-- Nome -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nome *</label>
        <input
          type="text"
          name="nome"
          required
          autocomplete="name"
          class="w-full rounded-md border border-gray-300 px-4 py-2.5 focus:border-gray-700 focus:ring-2 focus:ring-gray-700/20"
          placeholder="Il tuo nome"
        />
      </div>

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
        <input
          type="email"
          name="email"
          id="email"
          required
          autocomplete="email"
          class="w-full rounded-md border border-gray-300 px-4 py-2.5 focus:border-gray-700 focus:ring-2 focus:ring-gray-700/20"
          placeholder="mario@esempio.it"
        />
      </div>

      <!-- Telefono -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Telefono</label>
        <input
          type="tel"
          name="telefono"
          autocomplete="tel"
          class="w-full rounded-md border border-gray-300 px-4 py-2.5 focus:border-gray-700 focus:ring-2 focus:ring-gray-700/20"
          placeholder="+39 333 1234567"
        />
      </div>

      <!-- Servizio -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Servizio</label>
        <select
          name="servizio"
          class="w-full rounded-md border border-gray-300 px-4 py-2.5 focus:border-gray-700 focus:ring-2 focus:ring-gray-700/20"
        >
          <option value="">— Seleziona —</option>
          <option value="Ritratto Fine Art">Ritratto Fine Art</option>
          <option value="Corporate">Corporate</option>
          <option value="Ritratti persone famose">Ritratti persone famose</option>
          <option value="Altro">Altro</option>
        </select>
      </div>

      <!-- Messaggio -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Messaggio *</label>
        <textarea
          name="messaggio"
          rows="5"
          required
          class="w-full rounded-md border border-gray-300 px-4 py-2.5 focus:border-gray-700 focus:ring-2 focus:ring-gray-700/20 resize-none"
          placeholder="Scrivi qui la tua richiesta..."
        ></textarea>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        class="w-full rounded-md bg-gray-900 hover:bg-gray-800 text-white font-medium px-6 py-3 transition"
      >
        Invia Messaggio
      </button>

    </form>
    <!-- TURNSTILE -->
      <div class="flex justify-center mt-4">
        <div class="cf-turnstile" data-sitekey="0x4AAAAAAC8h4eqJDvK07CAM"></div>
      </div>
  </div>
</section>

<!-- Turnstile script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<!-- Reply-to sync -->
<script>
  const form = document.querySelector("form");
  const emailInput = document.getElementById("email");
  const replyto = document.getElementById("replyto-field");

  form?.addEventListener("submit", () => {
    if (emailInput && replyto) {
      replyto.value = emailInput.value;
    }
  });
</script>