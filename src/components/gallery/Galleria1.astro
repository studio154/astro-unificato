---
// Assets

// Fundations
import Text from "@/components/fundations/elements/Text.astro";
// Content
const { title, url, thumbnail, category } = {
  url: "/galleria/immagini/" + Astro.props.post.slug,
  title: Astro.props.post.data.title,
  category: Astro.props.post.data.category,
  thumbnail: Astro.props.post.data.thumbnail.url,
};
---

<article class="relative">
  
 <div class="relative group rounded-2xl overflow-hidden cursor-pointer">

  <img
    src={thumbnail}
    alt={title}
    category={category}
    loading="lazy"
    class="w-full object-contain object-center transition duration-1000 ease-out group-hover:scale-110 group-hover:brightness-75"
  />

  <!-- overlay più scenico -->
  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition duration-700"></div>

  <!-- testo centrato (effetto galleria) -->
  <div class="absolute inset-0 flex items-center justify-center z-10">
    <div class="text-center opacity-0 group-hover:opacity-100 transition duration-500">

      <p class="text-white text-xs tracking-[0.3em] uppercase opacity-70">
        Lavori selezionati
      </p>

      <h3 class="text-white text-2xl md:text-3xl font-light mt-2">
        {title}
      </h3>

    </div>
  </div>

  <a
    href={url}
    aria-label={`See more of: ${title}`}
    class="absolute inset-0 z-20"
  />

</div>
<div class="mt-4"><Text tag="h3" variant="base">{`Galleria: ${title}`}</Text
  >
  <Text tag="p" variant="textSM" class="text-base-900 border-b border-base-400">{category}</Text> </div>
 <!-- TESTO SOTTO LA FOTO -->
</article>
