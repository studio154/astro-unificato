---
const { title, description, canonical, image, ogType = "website" } = Astro.props;

import Meta from "@/components/fundations/head/Meta.astro";
import Fonts from "@/components/fundations/head/Fonts.astro";
import Favicons from "@/components/fundations/head/Favicons.astro";
const isTagPage = Astro.url.pathname.startsWith("/blog/tags/");
---

<Meta
  title={title}
  description={description}
  canonical={canonical}
  image={image}
  ogType={ogType}
/>

 {isTagPage && <meta name="robots" content="noindex, follow" />}

<Fonts />
<Favicons />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">

<script async src="https://www.googletagmanager.com/gtag/js?id=G-5PL5HD300T"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-5PL5HD300T');
</script>