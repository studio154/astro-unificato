---
import { AstroSeo } from "@astrolib/seo";

const {
  title,
  description,
  image,
  ogType = "website",
} = Astro.props;

const defaultTitle = "Elio Leonardo Carchidi | Fotografo di Ritratto a Roma";
const defaultDesc = "Da oltre 40 anni realizzo ritratti fotografici con luce naturale a Roma.";

// 🔴 Canonical SEMPRE corretto (ignora qualsiasi valore esterno)
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

// 🟡 OG Image: usa quella passata oppure fallback semplice
const ogImage = image?.url || image || "https://media.eliocarchidi.com/uploads/2026/03/blog-fotografia-elio-carchidi-bg-c.jpg";
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="theme-color" content="#ffffff" />

<AstroSeo
  title={title || defaultTitle}
  description={description || defaultDesc}
  canonical={canonicalUrl}
  openGraph={{
    url: canonicalUrl,
    title: title || defaultTitle,
    description: description || defaultDesc,
    images: [
      {
        url: ogImage,
        width: 1200,
        height: 630,
        alt: title || defaultTitle,
        type: "image/jpeg",
      },
    ],
    site_name: "Elio Leonardo Carchidi - Atelier Fotografico",
    type: ogType,
    locale: "it_IT",
  }}
  twitter={{
    handle: "@eliocarchidi",
    site: "@eliocarchidi",
    cardType: "summary_large_image",
  }}
/>