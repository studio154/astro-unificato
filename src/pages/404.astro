---
import BaseLayout from "@/layouts/BlogPostLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout hideBigLogo={true} hideNavigation={false} hideFooter={false}>
  <section>
    <Wrapper
      variant="standard"
      class="flex flex-col items-center justify-center py-24 text-center lg:py-32"
    >
      
      <!-- titolo -->
      <h1 class="text-2xl md:text-3xl font-light mb-4">
        Questa pagina non è disponibile
      </h1>

      <!-- testo -->
      <p class="text-sm md:text-base opacity-70 max-w-md mb-8 leading-relaxed">
        Stiamo aggiornando e modernizzando il sito con tecnologie più recenti. Durante la migrazione, alcuni contenuti potrebbero non essere ancora accessibili.
Puoi continuare la navigazione oppure contattarci per qualsiasi informazione.
      </p>

      <!-- azioni -->
      <div class="flex flex-col sm:flex-row gap-4 mt-2">
        <a href="/" class="text-sm underline">
          Continua la navigazione
        </a>
        <a href="/contatti/" class="text-sm underline">
          Contattaci
        </a>
      </div>

      <!-- spazio gallerie (opzionale, super consigliato) -->
      <!-- attiva quando vuoi -->
      <!--
      <div class="w-full max-w-5xl grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-16">
        <Galleria1 post={...} />
      </div>
      -->

    </Wrapper>
  </section>
</BaseLayout>