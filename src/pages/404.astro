---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Pagina non trovata">
  <script is:inline>
    // Se la pagina non esiste, dopo 2 secondi ti porto su contatti
    // Oppure puoi rimuovere lo script e mettere solo un link testuale
    setTimeout(() => {
      window.location.href = "/contatti/";
    }, 2000);
  </script>
  <div style="text-align: center; padding: 100px 20px;">
    <h1>Ops! Pagina non trovata.</h1>
    <p>Ti stiamo trasferendo alla pagina contatti...</p>
    <a href="/contatti/" style="text-decoration: underline;">Clicca qui se non vuoi attendere</a>
  </div>
</BaseLayout>