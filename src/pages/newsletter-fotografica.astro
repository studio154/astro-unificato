---
import BaseLayout from "../layouts/LayoutPagine.astro";
import NewsletterKit from "../components/cta/NewsletterKit.astro"
---

<BaseLayout title="Newsletter" description="Iscriviti alla newsletter di Elio Carchidi.">
  <main class="mx-auto max-w-2xl px-6 py-0">
    <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm">
      <h1 class="text-3xl font-bold tracking-tight">
        Newsletter
      </h1>

      <p class="mt-3 text-neutral-600">
        Fotografia, portfolio e strumenti per costruire un lavoro solido. Senza rumore.
      </p>

      <NewsletterKit />
  
</BaseLayout>