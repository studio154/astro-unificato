---
import BaseLayout from "../layouts/LayoutPagine.astro";
---

<BaseLayout title="Newsletter" description="Iscriviti alla newsletter di Elio Carchidi.">
  <main class="mx-auto max-w-2xl px-6 py-20">
    <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm">
      <h1 class="text-3xl font-bold tracking-tight">
        Newsletter
      </h1>

      <p class="mt-3 text-neutral-600">
        Fotografia, portfolio e strumenti per costruire un lavoro solido. Senza rumore.
      </p>

      <form
        method="post"
        action="https://sendfox.com/form/mp82gy/1x450n"
        class="sendfox-form mt-8"
        id="1x450n"
        data-async="true"
        data-recaptcha="true"
      >
        <div class="flex flex-col gap-4">
          <input
            type="text"
            id="sendfox_form_name"
            name="first_name"
            placeholder="Nome"
            required
            class="min-h-12 w-full rounded-full border border-neutral-300 px-5 text-sm outline-none transition focus:border-neutral-900 focus:ring-2 focus:ring-neutral-900/10"
          />

          <input
            type="email"
            id="sendfox_form_email"
            name="email"
            placeholder="Email"
            required
            class="min-h-12 w-full rounded-full border border-neutral-300 px-5 text-sm outline-none transition focus:border-neutral-900 focus:ring-2 focus:ring-neutral-900/10"
          />
        </div>

        <div style="position: absolute; left: -5000px;" aria-hidden="true">
          <input type="text" name="a_password" tabindex="-1" value="" autocomplete="off" />
        </div>

        <button
          type="submit"
          class="mt-5 min-h-12 w-full rounded-full bg-neutral-950 px-6 text-sm font-bold text-white transition hover:bg-neutral-800"
        >
          Iscriviti
        </button>

        <p class="mt-4 text-center text-xs text-neutral-500">
          Niente spam. Puoi disiscriverti in qualsiasi momento.
        </p>
      </form>
    </div>
  </main>

  <script src="https://cdn.sendfox.com/js/form.js" charset="utf-8"></script>
</BaseLayout>