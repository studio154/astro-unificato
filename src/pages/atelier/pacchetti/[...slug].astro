---
import { getCollection } from "astro:content";
import StoreLayout from "@/layouts/LayoutProdottoSingolo.astro";
export async function getStaticPaths() {
  const store = await getCollection("sessioni");
  const paths = store.map((page) => {
    return {
      params: { slug: page.slug },
      props: { page },

      trailingSlash: false,
    };
  });
  return paths;
}
const { page } = Astro.props;
const { Content } = await page.render();
---

<StoreLayout frontmatter={page.data}> <Content /></StoreLayout>
