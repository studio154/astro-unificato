---
import BaseLayout from "@/layouts/LayoutAcquistoEdizioni.astro";
import Wrapper from "@/components/fundations/containers/Wrapper-1040.astro";
import EditionForm from "@/components/hubspot-form/EdizioniFormspark.astro";

const pageTitle = "Richiedi le tue edizioni fotografiche";
const pageDescription =
  "Richiedi informazioni per l’acquisto di stampe fotografiche d’autore in tiratura limitata. Opere pensate per attraversare il tempo e abitare lo spazio.";
const canonical =
  "https://www.eliocarchidi.com/atelier/prenotazioni/edizioni-fotografiche/";
const image = "https://www.eliocarchidi.com/og-image-edizioni.jpg";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  image={image}
>
  <Wrapper variant="prose" class="py-2 m-auto">
    <EditionForm />
  </Wrapper>
</BaseLayout>