---
import BaseLayout from "@/layouts/LayoutRegala.astro";
import Wrapper from "@/components/fundations/containers/Wrapper-1040.astro";
import GiftForm from "@/components/hubspot-form/GiftRequestForm.astro";

const pageTitle = "Regala una sessione fotografica";
const pageDescription =
  "Regala un’esperienza di ritratto fotografico. Un tempo dedicato alla persona, alla luce e alla presenza, pensato per restare.";
const canonical =
  "https://www.eliocarchidi.com/atelier/prenotazioni/regalare-fotografie/";
const image = "https://www.eliocarchidi.com/og-image-regala.jpg";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  image={image}
>
  <Wrapper variant="prose" class="py-2 m-auto">
    <GiftForm />
  </Wrapper>
</BaseLayout>