---
import BaseLayout from "@/layouts/LayoutPrenotazioni.astro";
import Wrapper from "@/components/fundations/containers/Wrapper-1040.astro";
import SessionForm from "@/components/hubspot-form/SessioniFormspark.astro";

const pageTitle = "Richiedi la tua sessione fotografica";
const pageDescription =
  "Richiedi una sessione fotografica di ritratto a Roma. Un percorso su appuntamento, costruito intorno alla persona, alla luce e al risultato desiderato.";
const canonical =
  "https://www.eliocarchidi.com/atelier/prenotazioni/sessione-fotografica/";
const image = "https://www.eliocarchidi.com/og-image-sessione-fotografica.jpg";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  image={image}
>
  <Wrapper variant="default" class="py-2 m-auto">
    <SessionForm />
  </Wrapper>
</BaseLayout>