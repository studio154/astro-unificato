---
import BaseLayout from "@/layouts/LayoutContatti.astro";
import Wrapper from "@/components/fundations/containers/Wrapper-1040.astro";
import { AstroSeo } from "@astrolib/seo";
import ContattiQualificati from "@/components/hubspot-form/ContattiQualificati.astro";
---

<AstroSeo
  title="Richiedi la tua sessione fotografica"
  description="Sessioni Fotografiche Ritratto e Fotografia Corporate"
  canonical="https://www.eliocarchidi.com/contatti/"
  openGraph={{
    url: "https://www.eliocarchidi.com/contatti/",
    title: "Contatti Fotografo Professionista",
    description: "A detailed description of your page content.",
    images: [
      {
        url: "https://www.eliocarchidi.com/contatti/",
        width: 1200,
        height: 630,
        alt: "Open Graph Image Alt",
        type: "image/jpeg",
      },
    ],
    site_name: "https://www.eliocarchidi.com/contatti/",
    type: "website",
    locale: "it_IT",
  }}
  twitter={{
    handle: "@eliocarchidi",
    site: "@yeliocarchidi",
    cardType: "summary_large_image",
  }}
/>

<BaseLayout>
  

  <!-- <div class="my-12 text-center">
    <h1 class="text-2xl font-bold mb-4">
      Contattaci
    </h1>
    <p class="mb-6 text-gray-600">
      Ti ricontatteremo entro 24 ore per definire insieme i dettagli della tua
      richiesta.
    </p>
  </div> -->
  <Wrapper variant="prose" class="py-2 m-auto">
    <ContattiQualificati />
  </Wrapper>
</BaseLayout>
