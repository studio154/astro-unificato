---
import { getCollection } from "astro:content";
import LayoutProdottoSingolo from "../../../layouts/LayoutProdottoSingolo.astro";

export async function getStaticPaths() {
  const sessioni = await getCollection("sessioni");

  return sessioni.map((page) => ({
    params: { slug: page.slug },
    props: { page },
    trailingSlash: false,
  }));
}

const { page } = Astro.props;
const { Content } = await page.render();
---


<LayoutProdottoSingolo 
frontmatter={page.data}
  title={page.data.title}
  description={page.data.description}
  canonical={`https://www.eliocarchidi.com/atelier/sessioni-private/${page.slug}/`}
  image={page.data.image?.url || page.data.image}>
  <Content />
</LayoutProdottoSingolo>
