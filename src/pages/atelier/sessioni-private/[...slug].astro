---
import { getCollection } from "astro:content";
import StoreLayout from "../../../layouts/LayoutProdottoSingolo.astro";

// Genera i percorsi statici
export async function getStaticPaths() {
  const sessioni = await getCollection("sessioni");
  return sessioni.map((page) => ({
    params: { slug: page.slug },
    props: { page },
    trailingSlash: false,
  }));
}

// Recupera i dati della singola pagina
const { page } = Astro.props;
const { Content } = await page.render();
---

<StoreLayout frontmatter={page.data}>
  <Content />
</StoreLayout>
