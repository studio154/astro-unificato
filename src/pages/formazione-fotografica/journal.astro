---
import LayoutPagine from '../../layouts/LayoutCorso.astro';
// 2. Prendi i post
const posts = await Astro.glob('./*.md');
// 3. Ordinali
const sortedPosts = posts.sort((a, b) => 
  new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime()
);
---

<LayoutPagine title="Journal - Formazione Fotografica">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">Journal</h1>
    <p class="text-xl text-gray-600 mb-12">
      Riflessioni, tecniche e appunti sulla fotografia direttamente dalla bottega.
    </p>

    <div class="grid gap-12">
      {sortedPosts.map(post => (
        <article class="border-b pb-12">
          <h2 class="text-2xl font-bold mb-2">
            <a href={post.url} class="hover:text-accent transition-colors">
              {post.frontmatter.title}
            </a>
          </h2>
          <p class="text-gray-600 mb-4">
            {post.frontmatter.description}
          </p>
          <a href={post.url} class="text-sm font-bold uppercase tracking-widest hover:underline">
            Leggi l'articolo →
          </a>
        </article>
      ))}
    </div>
  </section>
</LayoutPagine>