---
import Layout from "@/layouts/LandingLayout.astro";
---
 
<Layout title="Messaggio ricevuto — Elio Carchidi">
 
  <section class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
 
    <p class="text-sm uppercase tracking-widest text-gray-400 mb-6">Grazie</p>
 
    <h1 class="text-3xl font-light text-gray-900 dark:text-gray-100 mb-4">
      Ho ricevuto il tuo messaggio.
    </h1>
 
    <p class="text-gray-500 dark:text-gray-400 max-w-sm leading-relaxed">
      Ti risponderò personalmente entro 24 ore.
    </p>
 
    <a
      href="/"
      class="mt-12 text-sm text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 underline underline-offset-4 transition"
    >
      Torna alla home
    </a>
 
  </section>
 
</Layout>