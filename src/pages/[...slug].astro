---
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import LayoutPagine from "@/layouts/LayoutPagine.astro";
import LayoutLanding from "@/layouts/LayoutLanding.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection("posts");
  const pagineEntries = await getCollection("pagine");

  const allEntries = [
    ...blogEntries.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry, type: "post" },
    })),
    ...pagineEntries.map((entry) => ({
      params: { slug: entry.slug },
      props: { entry, type: "pagina" },
    })),
  ];

  return allEntries;
}

const { entry, type } = Astro.props;
const { Content } = await entry.render();

const PageLayout = entry.data.pageStyle === "landing"
  ? LayoutLanding
  : LayoutPagine;
---

{type === "post" ? (
  <BlogLayout frontmatter={entry.data}>
    <Content />
  </BlogLayout>
) : (
  <PageLayout
    title={entry.data.title}
    description={entry.data.description}
    image={entry.data.image}
  >
    <Content />
  </PageLayout>
)}