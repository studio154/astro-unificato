---
// Assets
import BigLogo from "@/components/assets/LogoGrande.astro";
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/NavigazioneHamburgerStandard.astro";
// Hides the big logo, navigation, or footer on selected screens by passing props:
// <BaseLayout hideBigLogo={true} hideNavigation={true} hideFooter={true}>

const { hideBigLogo = false, hideNavigation = false, hideFooter = false } = Astro.props;
import Favicons from '../components/fundations/head/Favicons.astro';
---



<html lang="it" class="scroll-smooth">
  <head>
     <Favicons />
    <BaseHead />
  </head>
  <body class="flex flex-col min-h-svh">
    {
      !hideBigLogo && (
        <Wrapper variant="standard" class="pt-8">
          <BigLogo />
        </Wrapper>
      )
    }
    {!hideNavigation && <Navigation />}
    <main class="grow"><slot /></main>
    {!hideFooter && <Footer />}
  </body>
</html>

<style is:global>
  .prose img {
    /* Rimuoviamo aspect-ratio e object-fit */
    width: auto;
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2rem auto !important;
    border-radius: 1rem !important;
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
  }
  
  
  /* 1. Il contenitore principale della Notice */
  .wp-block-genesis-blocks-gb-notice {
    padding: 2.5rem !important; /* Padding generoso */
    margin: 3rem 0 !important;
    border-radius: 1.5rem !important; /* Angoli arrotondati come le foto */
    background-color: #f3f4f6 !important; /* Grigio chiaro neutro (o il colore che preferisci) */
    border: 1px solid #c2c2c2 !important;
    color: #c2c3c4 !important; /* Testo scuro leggibile */
  }

  /* 2. Il titolo dentro la Notice */
  .gb-notice-title {
    margin-bottom: 1rem !important;
  }
  
  .gb-notice-title p {
    font-size: 1.5rem !important;
    font-weight: 700 !important;
    color: #111827 !important; /* Titolo quasi nero */
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* 3. Il testo e i link dentro la Notice */
  .gb-notice-text {
    border: none !important; /* Rimuove il bordo colorato di Genesis */
    padding: 2em !important;
  }

  .gb-notice-text p {
    line-height: 1.6 !important;
    color: #4b5563 !important;
  }

  .gb-notice-text a {
    color: #4f46e5 !important; /* Un bel blu per i link CTA */
    text-decoration: underline !important;
    text-underline-offset: 4px;
  }

</style>
