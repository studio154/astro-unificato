---
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BaseLayout from "@/layouts/BlogPostLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import { getCollection } from "astro:content";

const { frontmatter } = Astro.props;

const allPosts = await getCollection("posts");

const relatedPosts = allPosts
  .filter((post) => post.slug !== frontmatter.slug)
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))
  .slice(0, 3);

const slug = Astro.url.pathname.split("/").filter(Boolean).pop();

const canonical = `https://www.eliocarchidi.com/${slug}/`;

const getPostUrl = (post) => `/${post.slug}/`;
---



<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  canonical={canonical}
  image={frontmatter.image}
  ogType="article"
  hideBigLogo={true}
  hideNavigation={false}
>
  

<Wrapper variant="standard">
<div class="max-w-xl mx-auto text-center text-base-900 pt-24">
        <Text
          tag="a"
          href="/blog/"
          variant="textlg"
          class="inline-flex items-center gap-1 hover: transition-colors font-medium"
        >
          &larr; Blog
        </Text></div>

  <!-- HERO / HEADER -->
  <section class="py-16 md:py-24 lg:py-32">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-2 gap-x-16 gap-y-16 items-start">

      <!-- TESTO -->
      <div class="max-w-xl">

        {frontmatter.category && (
          <p class="text-sm font-semibold text-indigo-600 uppercase tracking-wide">
            {frontmatter.category}
          </p>
        )}

        <h1 class="text-4xl md:text-5xl font-serif  font-[200] text-black tracking-wide leading-tight "
         style="font-family: 'Newsreader', serif;">
          {frontmatter.title}
        </h1>

        <div class="flex items-center gap-4 text-sm text-gray-500 mt-4">
          <span class="font-medium">{frontmatter.author ?? "Elio L. Carchidi"}</span>
          <span>•</span>
          <span>
            {new Date(frontmatter.pubDate).toLocaleDateString("it-IT", {
              year: "numeric",
              month: "long",
              day: "2-digit",
            })}
          </span>
        </div>

        {frontmatter.description && (
          <p class="mt-6 text-m text-gray-700 leading-relaxed">
            {frontmatter.description}
          </p>
        )}

      </div>

      <!-- IMMAGINE -->
      {frontmatter.image && (
  <div class="w-full aspect-[16/9] md:aspect-[21/9] relative bg-slate-900 overflow-hidden rounded-xl mb-12">
    
    <img
      src="https://media.eliocarchidi.com/uploads/2026/03/blog-fotografia-elio-carchidi-bg-c.jpg" 
      alt=""
      class="absolute inset-0 object-cover w-full h-full opacity-40 grayscale"
    />

    <div class="absolute inset-0 bg-black/30"></div>
    
    <div class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center z-10">
       
       <h1 
         class="text-white text-3xl lg:text-2xl font-serif  font-[200] tracking-wide leading-tight "
         style="font-family: 'Newsreader', serif;"
       >
         {frontmatter.title}
       </h1>
       {/* {frontmatter.description && (
     <p class="text-white/80 text-sm md:text-base font-sans mt-4 max-w-2xl mx-auto line-clamp-2">
       {frontmatter.description}
     </p>
   )} 
*/}
    </div>
  </div>
)}
    </div>
  </section>

  <!-- CONTENUTO -->
  <section class="pb-24">
    <div class="mx-auto max-w-3xl font-serif">

      <div class="prose prose-lg text-xl">
        <slot />
      </div>

      <!-- TAG -->
      {frontmatter.tags && (
        <div class="flex flex-wrap gap-2 mt-12 pt-6 border-t border-gray-200">
          {frontmatter.tags.map(tag => (
            <span class="text-xs border px-3 py-1 rounded-full text-gray-600">
              {tag}
            </span>
          ))}
        </div>
      )}

    </div>
  </section>

</div>
  {relatedPosts.length > 0 && (
  <section class="mt-32 border-t border-gray-200 pt-16">
    <div class="max-w-6xl mx-auto px-6">

      <!-- Titolo -->
      <h2 class="text-2xl font-semibold text-gray-900 mb-10">
        Articoli correlati
      </h2>

      <!-- Grid -->
      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-3">

        {relatedPosts.slice(0, 3).map((post) => (
          <article class="group">

            <a href={getPostUrl(post)} class="block">

              {/* Immagine */}
{post.data.image && (
  <div class="overflow-hidden rounded-lg mb-4 aspect-[16/9] bg-gray-100"> 
    <img
      src={post.data.image.url}
      alt={post.data.image.alt}
      class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
    />
  </div>
)}

              {/* Categoria - Leggermente più grande e leggibile */}
{post.data.category && (
  <p class="text-sm uppercase tracking-widest text-indigo-600 mb-3 font-semibold">
    {post.data.category}
  </p>
)}

{/* Titolo - Più grande (text-xl) e con interlinea corretta */}
<h3 class="text-xl font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors leading-tight">
  {post.data.title}
</h3>

{/* Descrizione - Portata a text-base per uniformità con il corpo del testo */}
{post.data.description && (
  <p class="text-base text-gray-600 mt-3 line-clamp-3 leading-relaxed">
    {post.data.description}
  </p>
)}

            </a>
          </article>
        ))}

      </div>

    </div>
  </section>
)}
</Wrapper>
</BaseLayout>