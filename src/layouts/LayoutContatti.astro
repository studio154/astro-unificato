---
// Assets
import BigLogo from "@/components/assets/LogoContatti.astro";
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/NavigazioneContatti.astro";
// Hides the big logo, navigation, or footer on selected screens by passing props:

const {
  hideBigLogo = true,
  hideNavigation = false,
  hideFooter = false,
} = Astro.props;
---

<html lang="it" class="scroll-smooth">
  <head>
    <BaseHead />
  </head>

  <body class="flex flex-col bg-gallery-1 min-h-svh">
   
   {
      !hideNavigation && (
        <Wrapper variant="standard" class="pt-8 mb-0">
          <Navigation />
        </Wrapper>
      )
    }
    {
      !hideBigLogo && (
        <Wrapper variant="standard" class="pt-8">
          <BigLogo />
        </Wrapper>
      )
    }

   

    <main class="grow mt-2"><slot /></main>

    {!hideFooter && <Footer />}
  </body>
</html>
