---
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/NavigazioneHamburgerStandard.astro";
import TopBarFormazione from "../components/cta/TopBarFormazione.astro";

const {
  title,
  description,
  canonical,
  image,
  ogType,
  hideBigLogo = false,
  hideNavigation = false,
  hideFooter = false,
} = Astro.props;
---

<html lang="it" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      ogType={ogType}
    />
  </head>

  <body class="flex flex-col bg-white min-h-svh">
    <TopBarFormazione />

    {
      !hideBigLogo && (
        <Wrapper variant="standard" class="pt-8">
          <BigLogo />
        </Wrapper>
      )
    }

    {!hideNavigation && <Navigation />}

    <main class="grow">
      <slot />
    </main>

    {!hideFooter && <Footer />}
  </body>
</html>