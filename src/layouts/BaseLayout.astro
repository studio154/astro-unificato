---
// Assets
import BigLogo from "@/components/assets/LogoIndex.astro";
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/NavigazioneIndex.astro";
// Hides the big logo, navigation, or footer on selected screens by passing props:
// <BaseLayout hideBigLogo={true} hideNavigation={true} hideFooter={true}>

const {
  title,
  description,
  canonical,
  image,
  ogType,
  hideBigLogo = false, hideNavigation = false, hideFooter = false } = Astro.props;
import Favicons from '../components/fundations/head/Favicons.astro';
---



<html lang="it" class="scroll-smooth">
  <head>
     <Favicons />
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      ogType={ogType}
    />
  </head>
  <body class="flex flex-col bg-white min-h-svh">
    {
      !hideBigLogo && (
        <Wrapper variant="standard" class="pt-8">
          <BigLogo />
        </Wrapper>
      )
    }
    {!hideNavigation && <Navigation />}
    <main class="grow"><slot /></main>
    {!hideFooter && <Footer />}
  </body>
</html>
