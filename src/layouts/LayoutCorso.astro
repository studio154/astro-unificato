---
// 1. RECUPERO DATI DAL MARKDOWN
const { frontmatter } = Astro.props;

// Se frontmatter esiste, prendiamo i dati da lì, altrimenti da Astro.props
const title = frontmatter?.title || Astro.props.title;
const description = frontmatter?.description || Astro.props.description;
const image = frontmatter?.image || Astro.props.image;

import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Favicons from '@/components/fundations/head/Favicons.astro';
import Footer from "@/components/global/Footer.astro";
import NavigationHamburger from "@/components/global/NavigazioneHamburger.astro";
import "@/styles/global.css";

const baseUrl = "https://media.eliocarchidi.com/uploads";
let finalImageUrl = null;

if (image) {
    const cleanPath = image.replace(/^(.*?)(wp-content\/uploads\/|uploads\/)?/, '').replace(/^\//, '');
    finalImageUrl = `${baseUrl}/${cleanPath}`;
}

// DEBUG: Vedrai questi messaggi nel terminale (nero) dove gira Astro
console.log("--- DEBUG LAYOUT ---");
console.log("Titolo trovato:", title);
console.log("Immagine originale:", image);
console.log("Immagine finale calcolata:", finalImageUrl);
---

<html lang="it" class="scroll-smooth">
  <head>
    <Favicons />
    <BaseHead 
  title={title} 
  description={description} 
  image={finalImageUrl} 
/>
  </head>
  
  <body class="flex flex-col bg-white min-h-svh">
    <NavigationHamburger />

    <main class="grow">
      <article class="max-w-4xl mx-auto px-6 py-20">
        <header class="text-center mb-16">
          <h1 class="titolo-testata-fisso">{title}</h1>
          
          {finalImageUrl && (
            <div class="mt-12 rounded-2xl overflow-hidden shadow-xl aspect-video bg-slate-100">
              <img src={finalImageUrl} alt={title} class="w-full h-full object-cover" />
            </div>
          )}
        </header>

        <div class="prose prose-lg md:prose-xl prose-slate mx-auto max-w-none">
          <slot />
          
          <footer class="mt-20 pt-10 border-t border-slate-200 not-prose">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-6">
              <a href="javascript:history.back()" class="text-slate-600 hover:text-black font-medium flex items-center transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Torna alla pagina precedente
              </a>
              
              <a href="/formazione-fotografica/risorse-gratuite-per-fotografi/corso-gratuito-di-fotografia/" class="bg-slate-900 text-white px-6 py-3 rounded-full text-sm font-bold uppercase tracking-widest hover:bg-slate-700 transition-all shadow-md">
                Sommario del Corso
              </a>
            </div>
          </footer>
        </div>
      </article>
    </main>

    <Footer />
  </body>
</html>

<style is:global>
  /* ... i tuoi stili CSS rimangono invariati ... */
  .titolo-testata-fisso { display: none !important; }
  /* ecc... */
</style>