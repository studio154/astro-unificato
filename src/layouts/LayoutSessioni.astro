---
// Assets
import BigLogo from "@/components/assets/LogoSessioni.astro";
// Fundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Components
import Footer from "@/components/global/Footer.astro";
import Navigation from "@/components/global/NavigazioneSessioni.astro";
// Hides the big logo, navigation, or footer on selected screens by passing props:


const {
  title,
  description,
  canonical,
  image,
  ogType,
  hideBigLogo = false, hideNavigation = false, hideFooter = false } = Astro.props;
---

<html lang="it" class="scroll-smooth">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      ogType={ogType}
    />
  </head>
  
  
  <body class="flex flex-col bg-gallery-6 min-h-svh">
    
    {
      !hideBigLogo && (
        <Wrapper variant="standard" class="pt-8">
          <BigLogo />
        </Wrapper>
      )
    }
   
    {!hideNavigation && <Navigation />}

    
    <main class="grow"><slot /></main>
    
    {!hideFooter && <Footer />}
   
  </body>
</html>
