---
const { frontmatter } = Astro.props;

import BaseLayout from "@/layouts/BaseLayout.astro";

const title =
  frontmatter?.title || frontmatter?.page || "Elio Leonardo Carchidi";

const description =
  frontmatter?.description ||
  "Da oltre 40 anni realizzo ritratti fotografici con luce naturale a Roma.";
---

<BaseLayout
  title={title}
  description={description}
>
  <main class="content">
    <slot />
  </main>
</BaseLayout>

<style>
  .content {
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem;
    font-family: system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .content h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .content h2 {
    margin-top: 2rem;
  }

  .content p {
    line-height: 1.6;
  }

  :global(.content img) {
    max-width: 100%;
    width: 100%;
  }
</style>